{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "allowImportingTsExtensions": true,
    "isolatedModules": true
  },
  "include": ["vite.config.ts", "electron"]
}
